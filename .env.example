# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Feature flags
VITE_CLIENT_THEME_V2=

# PostHog (analytics OS)
# Get the key from PostHog Cloud → Project Settings → Project API key.
# Leave VITE_POSTHOG_KEY unset locally to no-op the SDK in dev.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
